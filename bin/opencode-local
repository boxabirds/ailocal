#!/usr/bin/env bash
# opencode-local — wrapper that ensures mlx-lm is running, then runs opencode.
#
# - If the local mlx-lm endpoint is already healthy, runs opencode immediately.
# - If not, starts the server (~5-10s model load) and waits before running it.
# - Server stays up after this command exits — use `mlxlm-stop` to free RAM.
#   The idle watcher also keeps it alive while any opencode process is running.
#
# Pair with the qwen-mlxlm agent in your opencode config:
#   opencode-local --agent qwen-mlxlm
#
# This is a separate command from `opencode` so you can still call `opencode`
# directly (e.g. against a non-local provider) without forcing local startup.
#
# Add to your shell rc if you want this to be the default:
#   alias opencode=opencode-local

set -uo pipefail

INVOKE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SELF_PATH="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || python3 -c 'import os,sys;print(os.path.realpath(sys.argv[1]))' "${BASH_SOURCE[0]}")"
REAL_DIR="$(cd "$(dirname "$SELF_PATH")" && pwd)"
HEALTH_URL="http://127.0.0.1:8080/v1/models"

# Locate the real opencode binary, skipping anything in our own dirs (avoids
# self-recursion if the user has aliased or symlinked opencode -> opencode-local).
REAL_OPENCODE=""
IFS=":" read -ra paths <<<"$PATH"
for d in "${paths[@]}"; do
  [ -x "$d/opencode" ] || continue
  cand_dir="$(cd "$d" && pwd)"
  [ "$cand_dir" = "$INVOKE_DIR" ] && continue
  [ "$cand_dir" = "$REAL_DIR" ] && continue
  REAL_OPENCODE="$d/opencode"
  break
done
if [ -z "$REAL_OPENCODE" ]; then
  echo "opencode-local: cannot find real 'opencode' binary on PATH (excluding $INVOKE_DIR, $REAL_DIR)" >&2
  exit 127
fi

# Source ailocal.conf (default agent, EXA_API_KEY, AILOCAL_SERVE_SCRIPT, etc).
CONFIG_FILE="$HOME/.pi/ailocal.conf"
if [ -f "$CONFIG_FILE" ]; then
  # shellcheck disable=SC1090
  . "$CONFIG_FILE"
fi

# Determine which agent will be active (CLI override wins; else default).
ACTIVE_AGENT="${OPENCODE_DEFAULT_AGENT:-qwen-mlxlm}"
i=1; argv=("$@")
while [ $i -le ${#argv[@]} ]; do
  case "${argv[i-1]}" in
    --agent=*) ACTIVE_AGENT="${argv[i-1]#--agent=}" ;;
    --agent)   i=$((i+1)); ACTIVE_AGENT="${argv[i-1]:-$ACTIVE_AGENT}" ;;
  esac
  i=$((i+1))
done

# Pick the serve script that matches this agent's runtime. dsv4-mlxlm needs
# mlx-lm built from PR #1192 (POC 6); other agents use whatever the conf file
# has (POC 5 mlx-vlm by default, or POC 1 mlx-lm if --text-only at install).
REPO_ROOT="$(cd "$REAL_DIR/.." && pwd)"
case "$ACTIVE_AGENT" in
  dsv4-mlxlm)
    DSV4_SERVE="$REPO_ROOT/pocs/06-mlx-lm-dsv4/serve.sh"
    if [ ! -x "$DSV4_SERVE" ]; then
      echo "opencode-local: dsv4-mlxlm needs $DSV4_SERVE — not found or not executable." >&2
      echo "  Run install.sh after pulling, or set up POC 6 manually." >&2
      exit 1
    fi
    export AILOCAL_SERVE_SCRIPT="$DSV4_SERVE"
    ;;
esac

# Health check; start (or restart with the right runtime) if needed. mlxlm-start
# detects when the active serve script differs from what we just exported and
# restarts the server cleanly.
"$REAL_DIR/mlxlm-start" >&2 || exit 1

# Reveal Exa websearch tools to the agent. opencode only exposes Exa to its
# own provider unless this is set; for our custom mlxlm provider it's required.
# Caller env wins if already set.
export OPENCODE_ENABLE_EXA="${OPENCODE_ENABLE_EXA:-true}"

# Pass-through Exa key from env or ~/.pi/ailocal.conf (sourced above). Optional
# — without it, opencode hits mcp.exa.ai/mcp anonymously (rate-limited).
if [ -n "${EXA_API_KEY:-}" ]; then
  export EXA_API_KEY
fi

# Inject default --agent if the user didn't pass one (we already computed
# ACTIVE_AGENT above by parsing argv, so just echo whether it came from
# the CLI or the default).
user_passed_agent=0
for arg in "$@"; do
  case "$arg" in
    --agent|--agent=*) user_passed_agent=1; break ;;
  esac
done

if [ "$user_passed_agent" = "0" ] && [ -n "$ACTIVE_AGENT" ]; then
  exec "$REAL_OPENCODE" "$@" --agent "$ACTIVE_AGENT"
else
  exec "$REAL_OPENCODE" "$@"
fi
