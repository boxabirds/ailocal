#!/usr/bin/env bash
# mlxlm-start — start the mlx-lm server in the background if it isn't already.
# Idempotent: returns 0 quickly if the server is already healthy.
#
# When run interactively, prints the PID and tails the log path.
# When run by launchd, exec's serve.sh in the foreground (so launchd manages it).

set -uo pipefail

# Discover repo root from this script's location, following symlinks
# (so ~/.local/bin/mlxlm-start -> <repo>/bin/mlxlm-start works correctly).
SELF_PATH="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || python3 -c 'import os,sys;print(os.path.realpath(sys.argv[1]))' "${BASH_SOURCE[0]}")"
SELF_DIR="$(cd "$(dirname "$SELF_PATH")" && pwd)"
REPO_ROOT="$(cd "$SELF_DIR/.." && pwd)"
SERVE_SCRIPT="$REPO_ROOT/pocs/01-mlx-lm/serve.sh"
LOG_FILE="$HOME/Library/Logs/mlxlm.log"
PID_FILE="$HOME/.pi/mlxlm.pid"
HEALTH_URL="http://127.0.0.1:8080/v1/models"
WAIT_SECS=60

# Idle-stop config: env var > config file > default 300s. Set 0 to disable.
CONFIG_FILE="$HOME/.pi/ailocal.conf"
if [ -z "${MLXLM_IDLE_SECONDS:-}" ] && [ -f "$CONFIG_FILE" ]; then
  # shellcheck disable=SC1090
  . "$CONFIG_FILE"
fi
IDLE_SECONDS="${MLXLM_IDLE_SECONDS:-300}"

# Foreground mode for launchd: just exec serve.sh (no watcher; launchd
# manages KeepAlive and would just respawn after the watcher killed it).
if [ "${MLXLM_FOREGROUND:-0}" = "1" ]; then
  exec "$SERVE_SCRIPT"
fi

spawn_idle_watcher() {
  if [ "$IDLE_SECONDS" -le 0 ]; then return; fi
  WATCHER_SCRIPT="$SELF_DIR/mlxlm-idle-watcher"
  [ -x "$WATCHER_SCRIPT" ] || return
  # Don't double-spawn
  if [ -f "$HOME/.pi/mlxlm-watcher.pid" ]; then
    WATCHER_PID=$(cat "$HOME/.pi/mlxlm-watcher.pid" 2>/dev/null || echo "")
    if [ -n "$WATCHER_PID" ] && kill -0 "$WATCHER_PID" 2>/dev/null; then
      return
    fi
  fi
  MLXLM_IDLE_SECONDS="$IDLE_SECONDS" nohup "$WATCHER_SCRIPT" \
    >>"$HOME/Library/Logs/mlxlm-idle-watcher.log" 2>&1 &
  disown $! 2>/dev/null || true
  echo "Idle-stop watcher started (will stop mlx-lm after ${IDLE_SECONDS}s of no requests)"
}

# In already-running case we still want a watcher if none is running.
ensure_watcher_then_exit() {
  spawn_idle_watcher
  exit 0
}

mkdir -p "$(dirname "$LOG_FILE")" "$(dirname "$PID_FILE")"

# Already running?
if curl -fsS -m 1 "$HEALTH_URL" >/dev/null 2>&1; then
  echo "mlx-lm already running (health check OK at $HEALTH_URL)"
  ensure_watcher_then_exit
fi

echo "Starting mlx-lm — model loads ~33 GB, takes ~5-10s..."
nohup "$SERVE_SCRIPT" >>"$LOG_FILE" 2>&1 &
PID=$!
echo "$PID" > "$PID_FILE"
disown "$PID" 2>/dev/null || true

# Wait for /v1/models
for i in $(seq 1 "$WAIT_SECS"); do
  if curl -fsS -m 1 "$HEALTH_URL" >/dev/null 2>&1; then
    echo "Ready (PID $PID, log: $LOG_FILE)"
    spawn_idle_watcher
    exit 0
  fi
  sleep 1
done

echo "ERROR: mlx-lm did not become healthy within ${WAIT_SECS}s." >&2
echo "Last 20 log lines from $LOG_FILE:" >&2
tail -20 "$LOG_FILE" >&2
exit 1
